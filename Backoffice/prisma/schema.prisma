generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  CLIENT
  CALLER
}

enum PlanType {
  FREE
  LANDING
  LANDING_SUBSCRIPTION
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  TRIAL
}

model Tenant {
  id         String       @id @default(cuid())
  name       String
  slug       String       @unique
  status     TenantStatus @default(TRIAL)
  planId     String?
  plan       Plan?        @relation(fields: [planId], references: [id])
  users      User[]
  website    Website?
  mediaFiles MediaFile[]
  auditLogs  AuditLog[]
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
}

model Plan {
  id        String   @id @default(cuid())
  name      String
  type      PlanType
  priceEur  Float
  features  Json
  tenants   Tenant[]
  createdAt DateTime @default(now())
}

model User {
  id                String     @id @default(cuid())
  email             String     @unique
  passwordHash      String
  name              String
  role              Role       @default(CLIENT)
  tenantId          String?
  tenant            Tenant?    @relation(fields: [tenantId], references: [id])
  auditLogs         AuditLog[]
  resetToken        String?
  resetTokenExp     DateTime?
  impersonateToken  String?    @unique
  impersonateExpiry DateTime?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  // CRM (Lead Machine) back-relations — only populated for ADMIN / CALLER roles
  assignedLeads  LeadCrmState[] @relation("LeadOwner")
  leadActivities LeadActivity[]
  leadMeetings   LeadMeeting[]
  leadProposals  LeadProposal[]
  leadEmails     LeadEmailLog[]
}

model Website {
  id              String           @id @default(cuid())
  tenantId        String           @unique
  tenant          Tenant           @relation(fields: [tenantId], references: [id])
  contents        WebsiteContent[]
  events          Event[]
  socialLinks     SocialLink[]
  menuItems       MenuItem[]
  contentSchema   Json? // Array de ContentField definido pelo admin
  hasEvents       Boolean          @default(false)
  hasSocial       Boolean          @default(true)
  hasMenu         Boolean          @default(false)
  hasReservations Boolean          @default(false)
  publishedAt     DateTime?
  isDraft         Boolean          @default(true)
  vercelUrl       String?
  updatedAt       DateTime         @updatedAt
}

model WebsiteContent {
  id        String   @id @default(cuid())
  websiteId String
  website   Website  @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  key       String
  value     String   @db.Text
  updatedAt DateTime @updatedAt

  @@unique([websiteId, key])
}

model MediaFile {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  filename   String
  url        String
  r2Key      String
  size       Int
  mimeType   String
  uploadedAt DateTime @default(now())
}

model Event {
  id          String   @id @default(cuid())
  websiteId   String
  website     Website  @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  title       String
  description String?  @db.Text
  date        DateTime
  price       Float?
  capacity    Int?
  imageUrl    String?
  isPublished Boolean  @default(false)
  isEnded     Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SocialLink {
  id        String  @id @default(cuid())
  websiteId String
  website   Website @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  platform  String
  url       String
  icon      String
  order     Int     @default(0)
}

model MenuItem {
  id           String   @id @default(cuid())
  websiteId    String
  website      Website  @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  category     String
  name         String
  description  String?  @db.Text
  price        Float
  badge        String?
  imageUrl     String?
  isVegetarian Boolean  @default(false)
  isAvailable  Boolean  @default(true)
  order        Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  tenantId  String?
  tenant    Tenant?  @relation(fields: [tenantId], references: [id])
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  metadata  Json?
  createdAt DateTime @default(now())
}

// ═══════════════════════════════════════════════════════════════
// LEAD MACHINE — internal CRM domain (separate from CMS tenants)
// ═══════════════════════════════════════════════════════════════

enum LeadStatus {
  NEW
  CONTACTED
  REPLIED
  INTERESTED
  MEETING
  PROPOSAL
  CLOSED_WON
  CLOSED_LOST
}

enum LeadCallAnswer {
  PENDING
  YES
  NO_ANSWER
  VOICEMAIL
  WRONG_NUMBER
}

enum LeadOwnerType {
  UNKNOWN
  OWNER
  NOT_OWNER
}

enum LeadActivityType {
  NOTE
  CALL
  WHATSAPP
  EMAIL
  MEETING
  STATUS_CHANGE
  PROPOSAL_SENT
  OTHER
}

enum LeadOutcome {
  INTERESTED
  CALLBACK
  NOT_INTERESTED
  NO_ANSWER
  VOICEMAIL
  WRONG_NUMBER
}

enum LeadMeetingStage {
  DISCOVERY
  DEMO
  PROPOSAL
  CLOSING
  KICKOFF
  FOLLOW_UP
}

enum LeadMeetingStatus {
  SCHEDULED
  DONE
  NO_SHOW
  CANCELLED
  RESCHEDULED
}

enum LeadChannel {
  PHONE
  WHATSAPP
  EMAIL
  OTHER
}

enum LeadProposalStatus {
  DRAFT
  SENT
  ACCEPTED
  DECLINED
}

enum LeadBusinessType {
  RESTAURANT
  PROFESSIONAL
  RETAIL
  REAL_ESTATE
  BEAUTY
  GYM
  AUTO
  CONSTRUCTION
  CARPENTRY
  MOVING
  LAUNDRY
  DEFAULT
}

model Lead {
  id           String           @id @default(cuid())
  placeId      String?          @unique // Google Maps place_id for dedupe
  name         String
  category     String?
  keyword      String?
  city         String?
  address      String?
  lat          Float?
  lng          Float?
  phone        String?
  phoneClean   String? // 9 digits normalized
  whatsappLink String?
  email        String?
  website      String?
  rating       Float?
  reviews      Int              @default(0)
  googleUrl    String?
  businessType LeadBusinessType @default(DEFAULT)
  priority     Int              @default(0)
  source       String           @default("google_maps")
  enrichedAt   DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  crmState   LeadCrmState?
  activities LeadActivity[]
  meetings   LeadMeeting[]
  proposals  LeadProposal[]
  emails     LeadEmailLog[]

  @@index([city, businessType])
  @@index([priority])
  @@index([businessType])
}

model LeadCrmState {
  leadId String     @id
  lead   Lead       @relation(fields: [leadId], references: [id], onDelete: Cascade)
  status LeadStatus @default(NEW)

  // Call state
  answered        LeadCallAnswer @default(PENDING)
  isOwner         LeadOwnerType  @default(UNKNOWN)
  whoAnswered     String?
  noWebsiteReason String?
  bestCallTime    String?
  voicemailLeft   Boolean        @default(false)
  attempts        Int            @default(0)
  lastCallAt      DateTime?

  // General CRM state
  contactDate  DateTime?   @db.Date
  followUpDate DateTime?   @db.Date
  nextAction   String?
  channel      LeadChannel @default(WHATSAPP)
  dealValue    Decimal     @default(0) @db.Decimal(10, 2)
  lostReason   String?
  notes        String?     @db.Text

  ownerUserId String?
  owner       User?   @relation("LeadOwner", fields: [ownerUserId], references: [id])

  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([ownerUserId])
  @@index([followUpDate])
}

model LeadActivity {
  id        String           @id @default(cuid())
  leadId    String
  lead      Lead             @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?            @relation(fields: [userId], references: [id])
  type      LeadActivityType
  content   String?          @db.Text
  channel   LeadChannel?
  oldStatus LeadStatus?
  newStatus LeadStatus?
  metadata  Json?
  createdAt DateTime         @default(now())

  @@index([leadId, createdAt])
  @@index([userId, createdAt])
}

model LeadMeeting {
  id          String            @id @default(cuid())
  leadId      String
  lead        Lead              @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?             @relation(fields: [userId], references: [id])
  stage       LeadMeetingStage  @default(DISCOVERY)
  status      LeadMeetingStatus @default(SCHEDULED)
  startDt     DateTime
  durationMin Int               @default(30)
  meetLink    String?
  notes       String?           @db.Text
  outcome     String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([startDt])
  @@index([leadId])
  @@index([userId, status])
}

model LeadProposal {
  id             String             @id @default(cuid())
  leadId         String
  lead           Lead               @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId         String?
  user           User?              @relation(fields: [userId], references: [id])
  kind           String? // "rebuild" or "new"
  features       Json?
  addons         Json?
  totalOneTime   Decimal?           @db.Decimal(10, 2)
  totalRecurring Decimal?           @db.Decimal(10, 2)
  pdfUrl         String?
  status         LeadProposalStatus @default(DRAFT)
  sentAt         DateTime?
  createdAt      DateTime           @default(now())

  @@index([leadId])
  @@index([status])
}

model LeadEmailLog {
  id        String   @id @default(cuid())
  leadId    String?
  lead      Lead?    @relation(fields: [leadId], references: [id])
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  toAddress String
  subject   String?
  template  String?
  status    String? // sent, bounced, opened, clicked, failed
  error     String?
  sentAt    DateTime @default(now())

  @@index([leadId])
  @@index([toAddress])
}
